{
    "name":"particle-academy/fancy-git-gitlab",
    "description":"GitLab.com and Self-Managed adapter for particle-academy/fancy-git.",
    "type":"library","license":"MIT",
    "repositories":[{"type":"vcs","url":"https://github.com/Particle-Academy/fancy-git-php"}],
    "require":{"php":"^8.3","particle-academy/fancy-git":"^0.1.0","m4tthumphrey/php-gitlab-api":"^12.1","guzzlehttp/guzzle":"^7.15.1","http-interop/http-factory-guzzle":"^1.2"},
    "require-dev":{"phpunit/phpunit":"^11.0|^12.0"},
    "autoload":{"psr-4":{"FancyGit\\GitLab\\":"src/"}},
    "autoload-dev":{"psr-4":{"FancyGit\\GitLab\\Tests\\":"tests/"}},
    "scripts":{"test":"phpunit"},
    "config":{"allow-plugins":{"php-http/discovery":true}},
    "minimum-stability":"stable","prefer-stable":true,
    "support":{"issues":"https://github.com/Particle-Academy/fancy-git-gitlab-php/issues","source":"https://github.com/Particle-Academy/fancy-git-gitlab-php"}
}
